---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createSupabaseServerClient } from "../lib/supabase";

const supabase = createSupabaseServerClient({
  request: Astro.request,
  cookies: Astro.cookies
});

// Lấy thông tin người dùng hiện tại
const { data: { user } } = await supabase.auth.getUser();
let userProfile = null;

if (user) {
  const { data } = await supabase
    .from("profiles")
    .select("*")
    .eq("id", user.id)
    .single();
  userProfile = data;
}

// Tải danh sách bài viết thực từ CSDL Supabase
const { data: dbArticles } = await supabase
  .from("articles")
  .select("*")
  .eq("status", "published")
  .order("created_at", { ascending: false });

let articles = [];

if (dbArticles && dbArticles.length > 0) {
  articles = dbArticles.map(a => ({
    slug: a.slug,
    title: a.title,
    description: a.excerpt || "Khám phá phong cách thiết kế đồ họa máy tính thời kỳ đầu, cội nguồn của làn sóng nghệ thuật hoài cổ Vaporwave.",
    cover: a.cover_url || "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=600&auto=format&fit=crop",
    date: new Date(a.created_at).toLocaleDateString("vi-VN")
  }));
} else {
  // Dự phòng bài viết tĩnh mẫu ban đầu
  articles = [
    {
      slug: "retro-computing-aesthetic",
      title: "Hoài Niệm Windows 95: Vẻ Đẹp Của Hệ Điều Hành Cổ Điển",
      description: "Khám phá phong cách thiết kế đồ họa máy tính thời kỳ đầu, cội nguồn của làn sóng nghệ thuật hoài cổ Vaporwave.",
      cover: "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=600&auto=format&fit=crop",
      date: "2026-05-20"
    },
    {
      slug: "neon-dreamscape-art",
      title: "Neon Dreamscape: Sự Trỗi Dậy Của Không Gian Màu Neon 3D",
      description: "Tại sao những gam màu hồng rực rỡ và xanh điện tử tiếp tục thống trị nghệ thuật kỹ thuật số hiện đại.",
      cover: "https://images.unsplash.com/photo-1508739773434-c26b3d09e071?w=600&auto=format&fit=crop",
      date: "2026-05-18"
    }
  ];
}
---

<BaseLayout title="VAPORWAVE ART JOURNAL // HOME" userProfile={userProfile}>
  <!-- Tiêu đề lớn hiệu ứng Glitch chuẩn hóa Design System -->
  <div class="text-center py-8">
    <h1 class="hero-title text-glitch-soft">
      Vapor Journal
    </h1>
    <p class="text-[9px] sm:text-xs tracking-[0.25em] text-vapor-blue mt-3 font-mono uppercase">
      // A Cybernetic Oasis of Digital Nostalgia //
    </p>
  </div>

  <!-- Bố cục lưới bài viết toàn màn hình (Full-width articles grid) -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8 mt-10">
    {articles.map(article => (
      <div class="win95-container font-retro flex flex-col justify-between">
        <div>
          <div class="win95-header py-1">
            <span>ART_VIEWER.EXE</span>
            <button class="win95-btn py-0 px-1 text-[9px]" style="min-height: 18px;">?</button>
          </div>
          <div class="p-3 bg-win-gray">
            <div class="bg-black aspect-video max-h-[200px] overflow-hidden border border-win-dark flex items-center justify-center">
              <img 
                src={article.cover} 
                alt={article.title} 
                class="w-full h-full object-cover filter saturate-[1.1] contrast-[1.03] hover:scale-[1.02] transition-transform duration-300"
                loading="lazy"
                width="360"
                height="200"
              />
            </div>
            <h2 class="text-sm sm:text-base font-bold text-black mt-3 mb-2 uppercase line-clamp-2 leading-tight min-h-[40px]">{article.title}</h2>
            <p class="text-[10px] sm:text-xs text-black/85 leading-relaxed line-clamp-3">{article.description}</p>
          </div>
        </div>
        <div class="p-3 bg-win-gray pt-0 flex justify-between items-center">
          <span class="text-[9px] text-win-dark font-bold">{article.date}</span>
          <a href={`/articles/${article.slug}`} class="win95-btn no-underline inline-flex items-center px-4 py-1 text-black font-bold text-xs" style="min-height: 32px;">
            ĐỌC BÀI VIẾT >>
          </a>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
