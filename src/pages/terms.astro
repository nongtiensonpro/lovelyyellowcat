    </div>

    <!-- Main Content Window -->
    <div class="win95-container font-retro text-black mb-10 w-full">
        <div class="win95-header">
            <span>LEGAL_DISCLAIMER.SYS</span>
            <span class="text-[10px] text-vapor-yellow font-bold uppercase"
                >VERSION 1.0 // ACTIVE</span
            >
        </div>

        <div class="p-4 sm:p-6 bg-[#c0c0c0] space-y-6">
            <!-- Welcome Alert -->
            <div
                class="bg-white border-2 border-win-dark p-4 flex gap-4 items-start shadow-inner"
            >
                <span class="text-3xl">⚠️</span>
                <div class="text-xs space-y-1.5 text-win-dark">
                    <p class="font-bold text-black uppercase">
                        THÔNG BÁO QUAN TRỌNG DÀNH CHO KHÁCH TRUY CẬP:
