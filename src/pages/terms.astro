---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createSupabaseServerClient } from "../lib/supabase";

const supabase = createSupabaseServerClient({
    request: Astro.request,
    cookies: Astro.cookies,
});

// Lấy thông tin người dùng chỉ để hiển thị trên header nếu có
const {
    data: { user },
} = await supabase.auth.getUser();
let userProfile = null;
if (user) {
    const { data } = await supabase
        .from("profiles")
        .select("full_name, avatar_url, role")
        .eq("id", user.id)
        .single();
    userProfile = data;
}
---

<BaseLayout
    title="VAPORWAVE JOURNAL // ĐIỀU KHOẢN DỊCH VỤ & MIỄN TRỪ TRÁCH NHIỆM"
    userProfile={userProfile}
>

    <!-- Header -->
    <div class="text-center py-6">
        <h1
            class="text-3xl md:text-4xl font-extrabold uppercase tracking-widest text-vapor-pink font-retro"
        >
            📜 ĐIỀU KHOẢN & MIỄN TRỪ PHÁP LÝ
        </h1>
        <p
            class="text-xs tracking-wider text-vapor-blue mt-2 font-retro uppercase"
        >
            -- KHUNG PHÁP LÝ PHI THƯƠNG MẠI & BẢO VỆ SỞ HỮU TRÍ TUỆ DỰ ÁN
            VAPORWAVE MAGAZINE --
