---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { deleteCommentThread } from "../../lib/adminModeration";
import { sendCommentDeletedEmail } from "../../lib/emailNotification";
import { createSupabaseServerClient } from "../../lib/supabase";
import { env } from "cloudflare:workers";

const supabase = createSupabaseServerClient({
  request: Astro.request,
  cookies: Astro.cookies
});

// Lấy thông tin người dùng hiện tại
const { data: { user } } = await supabase.auth.getUser();
let userProfile = null;
if (user) {
  const { data } = await supabase
    .from("profiles")
    .select("*")
    .eq("id", user.id)
    .single();
  userProfile = data;
}

// Xử lý các hành động POST từ Admin (Xóa bình luận)
let actionResult: { success: boolean; message: string } | null = null;

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action");
  const commentId = formData.get("commentId") as string;
  const deleteReason = formData.get("deleteReason") as string || "";

  if (action === "delete" && commentId) {
    // Lấy thông tin bình luận + tác giả TRƯỚC khi xóa (để gửi email)
    let commentData: any = null;
    try {
      const { data } = await supabase
        .from("comments")
        .select("content, profile_id, profiles(email, full_name)")
        .eq("id", commentId)
        .single();
      commentData = data;
    } catch {}

    try {
      actionResult = await deleteCommentThread(supabase, commentId);
    } catch (err: any) {
      actionResult = { success: false, message: `Sự cố hệ thống: ${err.message}` };
    }

    // Gửi email thông báo nếu xóa thành công
    if (actionResult?.success && commentData?.profiles) {
      const profile = commentData.profiles as any;
      if (profile?.email) {
        try {
          await sendCommentDeletedEmail({
            recipientEmail: profile.email,
            recipientName: profile.full_name || profile.email,
            commentContent: commentData.content || "",
            reason: deleteReason || "Vi phạm quy tắc cộng đồng.",
            contactEmail: "nongtiensonpro@gmail.com",
          }, env);
        } catch (emailErr: any) {
          console.error("[COMMENTS] Email error:", emailErr.message);
        }
      }
    }
  } else {
    actionResult = { success: false, message: "Hành động không hợp lệ hoặc thiếu thông tin bình luận." };
  }
}

// Lấy danh sách bình luận
const { data: comments, error: fetchError } = await supabase
  .from("comments")
  .select(`
    id,
    content,
    created_at,
    article_id,
    profile_id,
    profiles (
      full_name,
      avatar_url
    )
  `)
  .order("created_at", { ascending: false });

const { count: commentsCount } = await supabase
  .from("comments")
  .select("*", { count: "exact", head: true });

const { count: pendingSubmissionsCount } = await supabase
  .from("submissions")
  .select("*", { count: "exact", head: true })
  .eq("status", "pending");
---

<BaseLayout title="VAPORWAVE MAGAZINE // QUẢN LÝ BÌNH LUẬN" userProfile={userProfile}>
  <!-- Menu Bar Quản Trị Viên -->
  <div class="win95-container w-full mb-6 font-retro">
    <div class="win95-header">
      <span>⚙️ ADMIN_CONTROL_PANEL.EXE</span>
    </div>
    <div class="flex gap-4 flex-wrap px-3 py-2 text-black text-xs bg-win-gray">
      <a href="/admin" class="hover:underline no-underline text-black">Bảng Điều Khiển</a>
      <a href="/admin/articles/new" class="hover:underline no-underline text-black">Viết Bài Mới</a>
      <a href="/admin/comments" class="hover:underline no-underline text-black font-bold">Duyệt Bình Luận ({commentsCount || 0})</a>
      <a href="/admin/submissions" class="hover:underline no-underline text-black">Duyệt Tranh Cộng Đồng ({pendingSubmissionsCount || 0})</a>
      {userProfile?.role === 'admin' && (
        <a href="/admin/users" class="hover:underline no-underline text-black">👥 Quản Lý Người Dùng</a>
      )}
    </div>
  </div>

  <!-- Thông báo kết quả hành động -->
  {actionResult && (
    <div class={`win95-container mb-6 font-retro text-xs ${actionResult.success ? "border-vapor-green" : "border-red-600"}`}>
      <div class={`win95-header ${actionResult.success ? "bg-gradient-to-r from-green-700 to-green-600" : "bg-gradient-to-r from-red-800 to-red-600"}`}>
        <span>{actionResult.success ? "✅ SYSTEM_LOG.OK" : "❌ SYSTEM_ALERT.ERR"}</span>
        <span class="text-[9px]">{new Date().toLocaleTimeString("vi-VN", { hour: '2-digit', minute: '2-digit', second: '2-digit' })}</span>
      </div>
      <div class={`p-3 text-black font-bold ${actionResult.success ? "bg-green-100" : "bg-red-100"}`}>
        <span class="mr-2">{actionResult.success ? "🟢" : "🔴"}</span>
        {actionResult.message}
      </div>
    </div>
  )}

  <!-- Thông báo lỗi tải dữ liệu -->
  {fetchError && (
    <div class="win95-container mb-6 font-retro text-xs border-red-600">
      <div class="win95-header bg-gradient-to-r from-red-800 to-red-600">
        <span>❌ DATABASE_ERROR.ERR</span>
      </div>
      <div class="p-3 text-black font-bold bg-red-100">
        🔴 Không thể tải danh sách bình luận: {fetchError.message}
      </div>
    </div>
  )}

  <!-- Header -->
  <div class="text-center py-6">
    <h1 class="text-3xl font-extrabold uppercase tracking-widest text-vapor-blue font-retro">
      💬 COMMENT MODERATION
    </h1>
    <p class="text-xs tracking-wider text-vapor-pink mt-2 font-retro uppercase">
      -- KIỂM DUYỆT VÀ ĐIỀU PHỐI CUỘC TRÒ CHUYỆN CỘNG ĐỒNG --
    </p>
  </div>

  <!-- Comments Moderation Table Area -->
  <div class="win95-container font-retro text-black mb-10">
    <div class="win95-header">
      <span>COMMENTS_DATABASE.DB</span>
      <span class="text-[10px] text-vapor-green">TOTAL: {commentsCount || 0} ITEMS</span>
    </div>

    <div class="bg-white overflow-x-auto border-2 border-win-dark p-1">
      <table class="w-full text-left border-collapse text-xs">
        <thead>
          <tr class="bg-[#c0c0c0] border-b border-win-dark">
            <th class="p-2 border-r border-win-dark font-bold w-48">NGƯỜI GỬI</th>
            <th class="p-2 border-r border-win-dark font-bold w-44">BÀI VIẾT (ID)</th>
            <th class="p-2 border-r border-win-dark font-bold">NỘI DUNG BÌNH LUẬN</th>
            <th class="p-2 border-r border-win-dark font-bold w-36">NGÀY GỬI</th>
            <th class="p-2 font-bold w-32 text-center">HÀNH ĐỘNG</th>
          </tr>
        </thead>
        <tbody>
          {!comments || comments.length === 0 ? (
            <tr>
              <td colspan="5" class="p-8 text-center text-win-dark font-bold">
                <span class="text-2xl block mb-2">💾</span>
                CHƯA CÓ BÌNH LUẬN NÀO ĐƯỢC GỬI TRÊN HỆ THỐNG.
              </td>
            </tr>
          ) : (
            comments.map((comment: any) => (
              <tr class="border-b border-[#e0e0e0] hover:bg-[#f5f5f5]">
                <td class="p-2 border-r border-[#e0e0e0] font-bold text-black">
                  <div class="flex items-center gap-2">
                    <img src={comment.profiles?.avatar_url || "/images/default-avatar.png"} class="w-6 h-6 border border-win-dark object-cover" alt="" />
                    <span class="break-all">{comment.profiles?.full_name || "Anonymous"}</span>
                  </div>
                </td>
                <td class="p-2 border-r border-[#e0e0e0]">
                  <a href={`/articles/${comment.article_id}`} class="font-mono text-[10px] text-vapor-purple hover:underline no-underline break-all" target="_blank">
                    {comment.article_id}
                  </a>
                </td>
                <td class="p-2 border-r border-[#e0e0e0] text-black italic max-w-md">
                  <div class="break-words line-clamp-3">"{comment.content}"</div>
                </td>
                <td class="p-2 border-r border-[#e0e0e0] text-win-dark text-[10px]">
                  {new Date(comment.created_at).toLocaleString("vi-VN")}
                </td>
                <td class="p-2 text-center">
                  <details class="relative">
                    <summary class="win95-btn font-bold text-red-700 text-[10px] px-3 py-1 hover:bg-red-100 cursor-pointer list-none">
                      ❌ XÓA
                    </summary>
                    <div class="absolute right-0 top-full z-50 mt-1 w-64 bg-[#c0c0c0] border-2 shadow-lg p-2 font-retro" style="border-color: #fff #808080 #808080 #fff;">
                      <form method="POST" class="m-0">
                        <input type="hidden" name="action" value="delete" />
                        <input type="hidden" name="commentId" value={comment.id} />
                        <label class="block text-[9px] font-bold mb-1 text-black">📋 Lý do xóa:</label>
                        <select name="deleteReasonPreset" class="w-full text-[10px] p-1 border border-win-dark bg-white mb-1 font-retro"
                          onchange={`this.form.deleteReason.value = this.value`}>
                          <option value="">-- Chọn lý do --</option>
                          <option value="Vi phạm quy tắc cộng đồng (ngôn từ không phù hợp).">Ngôn từ không phù hợp</option>
                          <option value="Spam hoặc nội dung quảng cáo.">Spam / Quảng cáo</option>
                          <option value="Nội dung gây hiểu lầm hoặc thông tin sai lệch.">Thông tin sai lệch</option>
                          <option value="Quấy rối hoặc bắt nạt người dùng khác.">Quấy rối</option>
                          <option value="Nội dung không liên quan đến chủ đề.">Không liên quan</option>
                        </select>
                        <textarea name="deleteReason" placeholder="Hoặc nhập lý do khác..." rows="2" class="w-full text-[10px] p-1 border border-win-dark bg-white mb-2 font-retro" style="resize:vertical;"></textarea>
                        <button type="submit" class="win95-btn w-full font-bold text-red-700 text-[10px] py-1 hover:bg-red-100" onclick="return confirm('⚠️ Xác nhận xóa bình luận này?');">
                          ❌ Xác nhận xóa
                        </button>
                      </form>
                    </div>
                  </details>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>

    <!-- Status Bar -->
    <div class="p-1.5 bg-win-gray border-t border-white text-[8px] text-win-dark font-retro flex justify-between">
      <span>COMMENT_MODERATION.SYS v1.0</span>
      <span>{commentsCount || 0} bình luận | Cập nhật: {new Date().toLocaleTimeString("vi-VN", { hour: '2-digit', minute: '2-digit' })}</span>
    </div>
  </div>
</BaseLayout>
