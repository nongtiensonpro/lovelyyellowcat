---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createSupabaseServerClient } from "../../lib/supabase";
import { RealtimeComments } from "../../components/RealtimeComments";
import { ReactionBar } from "../../components/ReactionBar";
import { parseMarkdownToHtml } from "../../lib/markdown";

const { slug } = Astro.params;

const supabase = createSupabaseServerClient({
  request: Astro.request,
  cookies: Astro.cookies
});

// Lấy thông tin người dùng hiện tại
const { data: { user } } = await supabase.auth.getUser();
let currentUser = null;

if (user) {
  const { data } = await supabase
    .from("profiles")
    .select("id, full_name, avatar_url")
    .eq("id", user.id)
    .single();
  currentUser = data;
}

// Tải thông tin bài viết từ CSDL Supabase
const { data: dbArticle } = await supabase
  .from("articles")
  .select("*, profiles:profiles!author_id(id, full_name)")
  .eq("slug", slug)
  .single();

// Đăng ký Promise song song tải bình luận và bài viết liên quan từ RPC
const [commentsRes, relatedRes] = await Promise.all([
  supabase.rpc("get_comment_tree", { p_article_id: slug || "" }),
  dbArticle 
    ? supabase.rpc("get_related_articles", { p_slug: slug || "", p_limit: 3 })
    : Promise.resolve({ data: [] })
]);

const initialComments = (commentsRes.data || []).map((c: any) => ({
  id: c.id,
  article_id: c.article_id,
  content: c.content,
  created_at: c.created_at,
  parent_id: c.parent_id,
  depth: c.depth,
  profiles: {
    id: c.profile_id,
    full_name: c.full_name,
    avatar_url: c.avatar_url
  }
}));
const relatedData = relatedRes.data || [];

let article = null;
let isStatic = false;

if (dbArticle) {
  article = {
    title: dbArticle.title,
    excerpt: dbArticle.excerpt || "Khám phá nghệ thuật hoài cổ Vaporwave...",
    content: dbArticle.body_md,
    cover: dbArticle.cover_url || "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=1000&auto=format&fit=crop",
    date: new Date(dbArticle.created_at).toLocaleDateString("vi-VN"),
    author: dbArticle.profiles?.full_name || "ADMIN",
    authorId: dbArticle.profiles?.id || null,
    tags: dbArticle.tags || [],
    view_count: dbArticle.view_count || 0
  };

  // Tăng lượt xem bài viết
  await supabase
    .from("articles")
    .update({ view_count: (dbArticle.view_count || 0) + 1 })
    .eq("id", dbArticle.id);
} else {
  // Dự phòng các bài viết tĩnh mẫu ban đầu
  if (slug === "retro-computing-aesthetic" || slug === "neon-dreamscape-art") {
    isStatic = true;
    article = {
      title: slug === "retro-computing-aesthetic" 
        ? "Hoài Niệm Windows 95: Vẻ Đẹp Của Hệ Điều Hành Cổ Điển"
        : "Neon Dreamscape: Sự Trỗi Dậy Của Không Gian Màu Neon 3D",
      excerpt: "Tìm hiểu cội nguồn và phong cách hoài cổ đặc thù của văn hóa Vaporwave.",
      content: "Không gian mạng (Cyberspace) và hoài cổ kỹ thuật số luôn là các chủ đề cốt lõi của nghệ thuật Vaporwave. Bằng cách sử dụng các hình ảnh kiến trúc cổ điển Hy Lạp kết hợp với giao diện desktop xám xi măng của Windows 95, các tác phẩm Vaporwave tạo ra cảm giác lơ lửng, hư vô của thời gian. Các đường kẻ CRT ngang màn hình cùng với hoạt ảnh lỗi kỹ thuật (glitch) không chỉ là công cụ trang trí, mà còn là bản tuyên ngôn phản kháng lại tính sắc sảo của thời kỳ đồ họa độ phân giải siêu cao ngày nay...",
      cover: slug === "retro-computing-aesthetic"
        ? "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=1000&auto=format&fit=crop"
        : "https://images.unsplash.com/photo-1508739773434-c26b3d09e071?w=1000&auto=format&fit=crop",
      date: "20/05/2026",
      author: "AESTHETIC WRITER",
      tags: ["vaporwave", "retro", "95"],
      view_count: 95
    };
  } else {
    // Không tìm thấy bài viết nào phù hợp -> quay lại trang chủ
    return Astro.redirect("/?error=article-not-found");
  }
}

// 1. Tạo liên kết Open Graph Image động và tối ưu hóa qua Cloudinary
let ogImageUrl = article.cover;
if (article.cover.includes("res.cloudinary.com")) {
  ogImageUrl = article.cover.replace("/image/upload/", "/image/upload/w_1200,h_630,c_fill,q_auto,f_auto/");
}

// 2. Xây dựng Structured Data JSON-LD
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.title,
  "description": article.excerpt,
  "image": article.cover,
  "datePublished": dbArticle ? dbArticle.published_at || dbArticle.created_at : "2026-05-20T00:00:00Z",
  "author": {
    "@type": "Person",
    "name": article.author,
    "url": article.authorId ? `${Astro.url.origin}/profile/${article.authorId}` : undefined
  },
  "publisher": {
    "@type": "Organization",
    "name": "Vaporwave Art Journal",
    "logo": {
      "@type": "ImageObject",
      "url": `${Astro.url.origin}/favicon.svg`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};

// 3. Logic đề xuất bài viết liên quan (Related Articles) kèm Fallback
let relatedArticles = [];
if (dbArticle) {
  if (relatedData && relatedData.length > 0) {
    relatedArticles = relatedData.map((art: any) => ({
      slug: art.slug,
      title: art.title,
      excerpt: art.excerpt || "Khám phá nghệ thuật Vaporwave...",
      cover: art.cover_url || "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=600&auto=format&fit=crop",
      date: new Date(art.created_at).toLocaleDateString("vi-VN")
    }));
  } else {
    // Fallback: Lấy 3 bài viết khác mới xuất bản gần đây
    const { data: fallbackArticles } = await supabase
      .from("articles")
      .select("*")
      .eq("status", "published")
      .neq("slug", slug)
      .order("created_at", { ascending: false })
      .limit(3);
    
    if (fallbackArticles) {
      relatedArticles = fallbackArticles.map((art: any) => ({
        slug: art.slug,
        title: art.title,
        excerpt: art.excerpt || "Khám phá nghệ thuật Vaporwave...",
        cover: art.cover_url || "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=600&auto=format&fit=crop",
        date: new Date(art.created_at).toLocaleDateString("vi-VN")
      }));
    }
  }
} else {
  // Fallback tĩnh cho các bài viết ban đầu
  const fallbackSlug = slug === "retro-computing-aesthetic" ? "neon-dreamscape-art" : "retro-computing-aesthetic";
  relatedArticles = [
    {
      slug: fallbackSlug,
      title: fallbackSlug === "retro-computing-aesthetic" 
        ? "Hoài Niệm Windows 95: Vẻ Đẹp Của Hệ Điều Hành Cổ Điển"
        : "Neon Dreamscape: Sự Trỗi Dậy Của Không Gian Màu Neon 3D",
      excerpt: "Khám phá phong cách thiết kế đồ họa máy tính thời kỳ đầu, cội nguồn của làn sóng nghệ thuật hoài cổ Vaporwave.",
      cover: fallbackSlug === "retro-computing-aesthetic"
        ? "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=600&auto=format&fit=crop"
        : "https://images.unsplash.com/photo-1508739773434-c26b3d09e071?w=600&auto=format&fit=crop",
      date: "20/05/2026"
    }
  ];
}
---

<BaseLayout 
  title={`${article.title} // VAPOR JOURNAL`} 
  description={article.excerpt}
  ogImage={ogImageUrl}
  canonicalUrl={Astro.url.href}
  articleJsonLd={articleJsonLd}
  userProfile={currentUser}
>
  <!-- Quay lại Trang chủ -->
  <div class="mb-6 font-retro">
    <a href="/" class="win95-btn no-underline inline-block text-black px-4 py-1.5 font-bold">
      &lt;&lt; QUAY LẠI TRANG CHỦ
    </a>
  </div>

  <!-- Chi tiết Bài báo -->
  <div class="win95-container w-full font-retro mb-6 text-black">
    <div class="win95-header">
      <span>EXPLORER.EXE - {article.title}</span>
      <button class="win95-btn py-0 px-1">?</button>
    </div>
    <div class="p-6 bg-win-gray">
      {article.cover && (
        <img src={article.cover} alt={article.title} class="w-full h-80 object-cover border-2 border-win-dark filter saturate-125 brightness-110 mb-6" />
      )}
      
      <div class="border-b border-win-dark pb-4 mb-6">
        <h1 class="text-2xl md:text-4xl font-extrabold uppercase leading-normal tracking-wide text-black">{article.title}</h1>
        <div class="flex flex-wrap gap-2 mt-3">
          {article.tags.map((tag) => (
            <span class="text-[9px] px-2 py-0.5 border border-win-dark bg-[#e0e0e0] font-bold">
              #{tag}
            </span>
          ))}
        </div>
        <div class="flex justify-between items-center text-[10px] text-win-dark mt-4">
          <span>
            Xuất bản lúc: {article.date} // Tác giả: {article.authorId ? (
              <a href={`/profile/${article.authorId}`} class="text-blue-800 hover:underline font-bold no-underline">
                {article.author}
              </a>
            ) : (
              article.author
            )}
          </span>
          <span class="font-mono">💾 LƯỢT XEM: {article.view_count}</span>
        </div>
      </div>

      {article.excerpt && (
        <p class="text-xs text-win-dark italic border-l-4 border-win-dark pl-3 mb-6 leading-relaxed">
          {article.excerpt}
        </p>
      )}

      {/* Nội dung bài viết hiển thị parse Markdown */}
      <article class="prose prose-sm font-sans text-justify text-black/90">
        <div set:html={parseMarkdownToHtml(article.content)} />
      </article>
    </div>
  </div>

  <!-- Thanh phản hồi Emoji bài viết (ReactionBar) -->
  <div class="mb-8">
    <ReactionBar client:load articleId={slug || "unknown"} currentUser={currentUser} />
  </div>

  <!-- Bài viết liên quan (Related Articles) kiểu Win95 3D nổi bật -->
  {relatedArticles.length > 0 && (
    <div class="win95-container w-full font-retro mb-10 text-black">
      <div class="win95-header">
        <span>RELATED_ARTICLES.SYS - [Bài Viết Liên Quan]</span>
        <button class="win95-btn py-0 px-1">?</button>
      </div>
      <div class="p-4 bg-[#c0c0c0]">
        <div class="grid sm:grid-cols-3 gap-4">
          {relatedArticles.map((related) => (
            <div class="border border-win-dark bg-white p-2.5 flex flex-col justify-between shadow-sm">
              <div>
                <img 
                  src={related.cover} 
                  alt={related.title} 
                  class="w-full h-28 object-cover border border-win-dark filter saturate-125" 
                />
                <h4 class="text-xs font-bold text-black mt-2 mb-1 line-clamp-2 leading-tight">
                  {related.title}
                </h4>
                <p class="text-[9px] text-win-dark line-clamp-2 leading-normal">
                  {related.excerpt}
                </p>
              </div>
              <div class="flex justify-between items-center pt-2 mt-2 border-t border-win-dark/10">
                <span class="text-[8px] text-win-dark font-mono">{related.date}</span>
                <a 
                  href={`/articles/${related.slug}`} 
                  class="win95-btn no-underline text-[8px] font-bold py-0.5 px-2 text-black"
                >
                  ĐỌC BÀI VIẾT &gt;
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Phân hệ bình luận thời gian thực (React Island tải trực tiếp trên client) -->
  <div class="max-w-3xl mx-auto mb-16">
    <h3 class="text-xl font-retro text-vapor-pink tracking-widest uppercase mb-4 text-center">
      // THẢO LUẬN NGHỆ THUẬT //
    </h3>
    <RealtimeComments 
      client:load 
      articleId={slug || "unknown"} 
      initialComments={initialComments} 
      currentUser={currentUser} 
    />
  </div>
</BaseLayout>
